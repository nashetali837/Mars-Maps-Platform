rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidMissionLog(data) {
      return data.keys().hasAll(['timestamp', 'type', 'message', 'roverId']) &&
             data.timestamp == request.time &&
             data.type in ['TELEMETRY', 'HAZARD', 'SYSTEM', 'ANALYSIS'] &&
             data.message is string && data.message.size() <= 1000 &&
             data.roverId is string;
    }

    function isValidRoverTelemetry(data) {
      return data.keys().hasAll(['roverId', 'aiPos', 'status', 'battery', 'updatedAt']) &&
             data.roverId is string &&
             data.status in ['active', 'calibrating', 'stuck'] &&
             data.battery is number && data.battery >= 0 && data.battery <= 100 &&
             data.updatedAt == request.time;
    }

    // Collection: Mission Logs
    match /logs/{logId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidMissionLog(incoming());
    }

    // Collection: Fleet Status
    match /fleet/{roverId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRoverTelemetry(incoming()) && isValidId(roverId);
      allow update: if isSignedIn() && isValidRoverTelemetry(incoming()) && (
        // Only allow updating status and battery during standard operations
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'battery', 'updatedAt', 'aiPos', 'imuPos', 'realPos'])
      );
    }

    // Collection: Trajectories
    match /trajectories/{planId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        incoming().keys().hasAll(['roverId', 'start', 'goal', 'path', 'createdAt']) &&
        incoming().createdAt == request.time
      );
    }
  }
}
